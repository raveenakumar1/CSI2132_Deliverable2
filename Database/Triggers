-- Trigger 1: Prevent deleting a hotel that has active bookings or rentings
CREATE OR REPLACE FUNCTION prevent_delete_hotel_with_active_records()
RETURNS TRIGGER AS $$
BEGIN
    -- Check if hotel has any active (not cancelled/completed) bookings
    IF EXISTS (
        SELECT 1 FROM BOOKING b
        WHERE b.Hotel_ID = OLD.Hotel_ID
        AND b.Status NOT IN ('Cancelled', 'Completed')
    ) THEN
        RAISE EXCEPTION 'Cannot delete hotel with active bookings. Status: %', 
        (SELECT string_agg(DISTINCT Status, ', ') FROM BOOKING 
         WHERE Hotel_ID = OLD.Hotel_ID AND Status NOT IN ('Cancelled', 'Completed'));
    END IF;
    
    -- Check if hotel has any active rentings (not completed)
    IF EXISTS (
        SELECT 1 FROM RENTING r
        WHERE r.Hotel_ID = OLD.Hotel_ID
        AND r.Status != 'Completed'
    ) THEN
        RAISE EXCEPTION 'Cannot delete hotel with active rentings.';
    END IF;
    
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_prevent_delete_hotel_with_active_records
BEFORE DELETE ON HOTEL
FOR EACH ROW EXECUTE FUNCTION prevent_delete_hotel_with_active_records();

-- Trigger 2: When a booking is converted to renting, update booking status
CREATE OR REPLACE FUNCTION update_booking_on_renting()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.Booking_ID IS NOT NULL THEN
        UPDATE BOOKING
        SET Status = 'Completed'
        WHERE Booking_ID = NEW.Booking_ID;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_convert_booking
AFTER INSERT ON RENTING
FOR EACH ROW EXECUTE FUNCTION update_booking_on_renting();
